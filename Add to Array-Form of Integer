// Problem no. 989. Add to Array-Form of Integer

class Solution {
    public List<Integer> addToArrayForm(int[] num, int k) {
        List<Integer> ans = new ArrayList<>();
        int sum = 0;
        for(int i = num.length - 1; i >= 0; i--){
            sum = num[i] + k;
            ans.add(sum % 10);
            k = sum / 10;
        }

        while(k > 0){
            ans.add(k % 10);
            k /= 10;
        }
        Collections.reverse(ans);
        return ans;
    }
}
