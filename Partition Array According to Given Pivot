2161. Partition Array According to Given Pivot

class Solution {
    public int[] pivotArray(int[] nums, int pivot) {
        int n = nums.length;
        int[] result = new int[n];

        int countless = 0;
        int countequal = 0;

        for(int num : nums){
            if(num < pivot)
                countless++;
            else if(num == pivot)
                countequal++;
        }

        int i = 0;
        int j = countless;
        int k = countless + countequal;

        for(int num : nums){
            if(num < pivot){
                result[i] = num;
                i++;
            } else if(num == pivot){
                result[j] = num;
                j++;
            } else {
                result[k] = num;
                k++;
            }
        }

        return result;
    }
}
