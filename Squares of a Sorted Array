977. Squares of a Sorted Array

class Solution {
    public int[] sortedSquares(int[] nums) {
        int n = nums.length;
        int i = 0;
        int j = n - 1;
        int k = n - 1;
        int arr[] = new int[n];
        while(i <= j){
            if(Math.abs(nums[i]) < Math.abs(nums[j])){
                arr[k--] = nums[j] * nums[j];
                j--;
            }
            else {
                arr[k--] = nums[i] * nums[i];
                i++;
            }
        }
        return arr;
    }
}
