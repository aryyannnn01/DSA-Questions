1358. Number of Substrings Containing All Three Characters

class Solution {
    public int numberOfSubstrings(String s) {
        int count = 0;
        int[] p = {-1, -1, -1};

        for(int i = 0; i < s.length(); i++){
            p[(s.charAt(i) & 31) - 1] = i;
            count += Math.min(p[0], Math.min(p[1], p[2])) + 1; 
        }

        return count;
    }
}
